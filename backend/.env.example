# AISStream Real-Time WebSocket API Key
# Register at https://aisstream.io to obtain your key
AISSTREAM_API_KEY=your-aisstream-api-key

# SMTP Configuration for Email Alerts
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_TO=authority@example.com

# Optional: Twilio SMS Alerts
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=

# Optional: Sentinel Hub Satellite API
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=
